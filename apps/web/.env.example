# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key (Server-side only, Keep it secret!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenRouter Configuration (Server-side only)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=WorkPresso
OPENROUTER_SITE_URL=http://localhost:3000
APP_SECRET_ENCRYPTION_KEY=change-this-to-a-strong-server-secret
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_MEETING_MODEL=google/gemini-flash-1.5
OPENROUTER_STT_MODEL=openai/gpt-4o-audio-preview

# Transitional fallback only
OPENAI_API_KEY=your_openai_api_key

# App URL (For Auth callback, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
